## Ignore Visual Studio temporary files, build results, and
## files generated by .NET / Visual Studio tooling.
##
## Based on https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Build output
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
[Oo]ut/
bld/
publish/
artifacts/
.artifacts/

# Visual Studio cache/options
.vs/
Generated\ Files/

# MSBuild / compiler generated files
*.cache
*.[Cc]ache
*.tlog
*.binlog
MSBuild_Logs/
*.pdb
*.mdb
*.ilk
*.idb
*.iobj
*.ipdb
*.obj
*.pch
*.rsp
!Directory.Build.rsp
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.pidb
*.svclog

# NuGet
packages/
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nupkg
*.snupkg
project.assets.json
project.nuget.cache
project.lock.json
project.fragment.lock.json
*.nuget.props
*.nuget.targets

# Test / coverage output
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
TestResult.xml
nunit-*.xml
coverage/
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# Rider / ReSharper
.idea/
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# VS Code local files
.vscode/
.history/

# Local game/mod folders copied by accident
CrushCrush_Data/
MelonLoader/
Mods/
BepInEx/
UserData/

# OS files
Thumbs.db
Desktop.ini
.DS_Store
